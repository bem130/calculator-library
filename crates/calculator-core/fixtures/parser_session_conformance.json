{
  "defaultParseSettings": {
    "grammar": "default",
    "implicitMultiplication": "enabled",
    "unicodeAliases": "mathematicalAliases",
    "percent": "postfixPercent"
  },
  "defaultSemanticSettings": {
    "domain": "real",
    "angleUnit": "radian",
    "powerSemantics": "realPrincipal"
  },
  "sourceCases": [
    {
      "id": "power_right_associative",
      "source": "2^3^2",
      "expectedParseTree": "power(number(2),power(number(3),number(2)))",
      "expectedExact": "512"
    },
    {
      "id": "unary_minus_binds_below_power",
      "source": "-2^2",
      "expectedParseTree": "negate(power(number(2),number(2)))",
      "expectedExact": "-4"
    },
    {
      "id": "power_exponent_accepts_unary_minus",
      "source": "2^-3",
      "expectedParseTree": "power(number(2),negate(number(3)))",
      "expectedExact": "1/8"
    },
    {
      "id": "implicit_multiplication_matches_division_precedence",
      "source": "2/3π",
      "expectedParseTree": "multiply[implicit](divide(number(2),number(3)),constant(pi))",
      "expectedExact": "2pi/3"
    },
    {
      "id": "parenthesized_implicit_multiplication",
      "source": "2(3+4)",
      "expectedParseTree": "multiply[implicit](number(2),add(number(3),number(4)))",
      "expectedExact": "14"
    },
    {
      "id": "string_percent_keeps_expression_meaning",
      "source": "100 + 10%",
      "expectedParseTree": "add(number(100),percent(number(10)))",
      "expectedExact": "1001/10"
    },
    {
      "id": "radian_special_angle_sine",
      "source": "sin(pi/6)",
      "expectedParseTree": "sin(divide(constant(pi),number(6)))",
      "expectedExact": "1/2"
    },
    {
      "id": "radian_tangent_pole",
      "source": "tan(pi/2)",
      "expectedParseTree": "tan(divide(constant(pi),number(2)))",
      "expectedError": "domain.tangentPole"
    },
    {
      "id": "simple_radical_sqrt",
      "source": "sqrt(72)",
      "expectedParseTree": "sqrt(number(72))",
      "expectedExact": "6sqrt(2)"
    },
    {
      "id": "bounded_square_factor_radical_sqrt",
      "source": "sqrt(6962)",
      "expectedParseTree": "sqrt(number(6962))",
      "expectedExact": "59sqrt(2)"
    },
    {
      "id": "radical_product_reduces_to_rational",
      "source": "sqrt(2)*sqrt(2)",
      "expectedParseTree": "multiply(sqrt(number(2)),sqrt(number(2)))",
      "expectedExact": "2"
    },
    {
      "id": "radical_quotient_reduces_to_rational",
      "source": "sqrt(8)/sqrt(2)",
      "expectedParseTree": "divide(sqrt(number(8)),sqrt(number(2)))",
      "expectedExact": "2"
    },
    {
      "id": "radical_special_angle",
      "source": "sin(pi/4)",
      "expectedParseTree": "sin(divide(constant(pi),number(4)))",
      "expectedExact": "sqrt(2)/2"
    },
    {
      "id": "mixed_rational_radical_exact_value",
      "source": "sin(pi/6)+sqrt(2)",
      "expectedParseTree": "add(sin(divide(constant(pi),number(6))),sqrt(number(2)))",
      "expectedExact": "1/2 + sqrt(2)"
    },
    {
      "id": "inverse_trigonometric_known_value",
      "source": "asin(1/2)",
      "expectedParseTree": "asin(divide(number(1),number(2)))",
      "expectedExact": "pi/6"
    },
    {
      "id": "radical_inverse_trigonometric_known_value",
      "source": "atan(sqrt(3))",
      "expectedParseTree": "atan(sqrt(number(3)))",
      "expectedExact": "pi/3"
    },
    {
      "id": "inverse_trigonometric_out_of_range",
      "source": "acos(-2)",
      "expectedParseTree": "acos(negate(number(2)))",
      "expectedError": "domain.inverseTrigonometricOutOfRange"
    }
  ],
  "parseErrorCases": [
    {
      "id": "leading_decimal_requires_integer_digits",
      "source": ".5",
      "expectedError": "invalidNumberLiteral",
      "expectedSpanUtf8": {
        "start": 0,
        "end": 1
      }
    },
    {
      "id": "trailing_decimal_requires_fraction_digits",
      "source": "1.",
      "expectedError": "invalidNumberLiteral",
      "expectedSpanUtf8": {
        "start": 0,
        "end": 2
      }
    },
    {
      "id": "function_call_requires_parentheses",
      "source": "sin 30",
      "expectedError": "missingFunctionParenthesis",
      "expectedSpanUtf8": {
        "start": 0,
        "end": 3
      }
    },
    {
      "id": "unicode_span_remains_utf8_at_core_boundary",
      "source": "π.",
      "expectedError": "invalidNumberLiteral",
      "expectedSpanUtf8": {
        "start": 2,
        "end": 3
      }
    }
  ],
  "sessionCases": [
    {
      "id": "expression_percent_command",
      "percentPolicy": "expressionPercent",
      "actions": [
        "digit:1",
        "digit:0",
        "digit:0",
        "binary:add",
        "digit:1",
        "digit:0",
        "percent",
        "evaluate"
      ],
      "expectedCommandSource": "100+10%",
      "expectedExact": "1001/10",
      "applyCommandResult": true,
      "expectedFinalState": {
        "source": "100+10%",
        "cursorUtf8": 7,
        "hasAns": true,
        "hasMemory": false
      }
    },
    {
      "id": "calculator_percent_command",
      "percentPolicy": "calculatorPercent",
      "actions": [
        "digit:1",
        "digit:0",
        "digit:0",
        "binary:add",
        "digit:1",
        "digit:0",
        "percent",
        "evaluate"
      ],
      "expectedCommandSource": "100+((100)*(10)/100)",
      "expectedExact": "110",
      "applyCommandResult": true,
      "expectedFinalState": {
        "source": "100+((100)*(10)/100)",
        "cursorUtf8": 20,
        "hasAns": true,
        "hasMemory": false
      }
    },
    {
      "id": "clear_entry_clear_all_ans_memory_state",
      "percentPolicy": "expressionPercent",
      "actions": [
        "digit:1",
        "evaluate",
        "applyCommandResult",
        "memoryAdd",
        "clearEntry",
        "clearAll"
      ],
      "expectedCommandSource": "1",
      "expectedExact": "1",
      "expectedFinalState": {
        "source": "",
        "cursorUtf8": 0,
        "hasAns": false,
        "hasMemory": true
      }
    },
    {
      "id": "error_result_does_not_set_ans_and_next_input_recovers",
      "percentPolicy": "expressionPercent",
      "actions": [
        "digit:1",
        "binary:divide",
        "digit:0",
        "evaluate",
        "applyCommandResult",
        "digit:2"
      ],
      "expectedCommandSource": "1/0",
      "expectedError": "domain.divisionByZero",
      "expectedFinalState": {
        "source": "2",
        "cursorUtf8": 1,
        "hasAns": false,
        "hasMemory": false
      }
    }
  ]
}
