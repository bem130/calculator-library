{
  "name": "@bem130/exact-calculator-vanilla-example",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare:wasm": "corepack pnpm --dir ../../packages/calculator run build:wasm && node scripts/copy-wasm.mjs",
    "dev": "corepack pnpm run prepare:wasm && vite --host 127.0.0.1",
    "build": "corepack pnpm run prepare:wasm && tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@bem130/exact-calculator": "file:../../packages/calculator"
  },
  "devDependencies": {
    "playwright": "^1.61.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0"
  }
}
